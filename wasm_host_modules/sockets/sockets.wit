package wasi:sockets;

/// @wit-import: "../../wasm_host_modules/threads/threads.wit"

/// @cpp-header: "embwasm_hostmodule_socket.hpp"
/// @cpp-init:   embwasm::hostmodules::wasi::sockets::sockets::initialize
/// @cpp-deinit: embwasm::hostmodules::wasi::sockets::sockets::deinitialize
interface sockets {
    // =========================================================================
    // ソケット ライフサイクル
    // =========================================================================

    /// TCP ソケットを作成する。成功時は非負のソケットハンドル、失敗時は -1 を返す。
    socket-create: func(domain: s32, %type: s32, protocol: s32) -> s32;

    /// ソケットを閉じる。成功時は 0、失敗時は -1 を返す。
    socket-close: func(sock: s32) -> s32;

    // =========================================================================
    // バインド / リッスン / アクセプト（サーバー側）
    // =========================================================================

    /// ソケットにアドレスをバインドする。
    /// addr_ptr は WASM 線形メモリ上の sockaddr_in 互換構造体へのオフセット。
    socket-bind: func(sock: s32, addr-ptr: s32, addr-len: s32) -> s32;

    /// バックログキューを持つサーバーソケットをリッスン状態にする。
    socket-listen: func(sock: s32, backlog: s32) -> s32;

    /// 接続を受け付ける。成功時は新しいソケットハンドル、失敗時は -1 を返す。
    /// peer_addr_ptr / peer_addr_len_ptr は省略可能 (0 を渡してよい)。
    socket-accept: func(sock: s32, peer-addr-ptr: s32, peer-addr-len-ptr: s32) -> s32;

    // =========================================================================
    // 接続（クライアント側）
    // =========================================================================

    /// リモートアドレスへ接続する。
    /// addr_ptr は WASM 線形メモリ上の sockaddr_in 互換構造体へのオフセット。
    socket-connect: func(sock: s32, addr-ptr: s32, addr-len: s32) -> s32;

    // =========================================================================
    // データ送受信
    // =========================================================================

    /// データを送信する。送信バイト数、または -1（エラー）を返す。
    socket-send: func(sock: s32, buf-ptr: s32, buf-len: s32, %flags: s32) -> s32;

    /// データを受信する。受信バイト数（0 は接続終了）、または -1（エラー）を返す。
    socket-recv: func(sock: s32, buf-ptr: s32, buf-len: s32, %flags: s32) -> s32;

    /// UDP 向け送信。addr_ptr に送信先アドレス（sockaddr_in）を指定する。
    socket-send-to: func(sock: s32, buf-ptr: s32, buf-len: s32, %flags: s32, addr-ptr: s32, addr-len: s32) -> s32;

    /// UDP 向け受信。src_addr_ptr / src_addr_len_ptr に送信元アドレスが書き込まれる。
    socket-recv-from: func(sock: s32, buf-ptr: s32, buf-len: s32, %flags: s32, src-addr-ptr: s32, src-addr-len-ptr: s32) -> s32;

    // =========================================================================
    // ソケットオプション
    // =========================================================================

    /// ソケットオプションを設定する（setsockopt 相当）。
    socket-set-opt: func(sock: s32, level: s32, optname: s32, optval-ptr: s32, optlen: s32) -> s32;

    /// ソケットオプションを取得する（getsockopt 相当）。
    socket-get-opt: func(sock: s32, level: s32, optname: s32, optval-ptr: s32, optlen-ptr: s32) -> s32;

    // =========================================================================
    // ノンブロッキング / select
    // =========================================================================

    /// ソケットのブロッキングモードを設定する（0: ブロッキング、1: ノンブロッキング）。
    socket-set-non-blocking: func(sock: s32, nonblocking: s32) -> s32;

    /// 単一ソケットに対する簡易 poll（タイムアウト: ミリ秒、-1 で無限待ち）。
    /// ready_mask を返す：bit0=readable、bit1=writable、bit2=error。
    socket-poll: func(sock: s32, events: s32, timeout-ms: s32) -> s32;

    // =========================================================================
    // アドレスユーティリティ
    // =========================================================================

    /// IPv4 アドレス文字列 (WASM 線形メモリ上) を 32bit ネットワークバイトオーダーに変換する。
    /// 変換失敗時は 0 を返す。
    inet-addr: func(addr-str-ptr: s32) -> s32;

    /// ホストバイトオーダーの16bit値をネットワークバイトオーダーに変換する。
    host-to-net-short: func(host-short: s32) -> s32;

    /// ネットワークバイトオーダーの16bit値をホストバイトオーダーに変換する。
    net-to-host-short: func(net-short: s32) -> s32;

    // =========================================================================
    // エラー情報
    // =========================================================================

    /// 最後に発生したソケットエラーコードを返す（errno / WSAGetLastError 相当）。
    socket-get-last-error: func() -> s32;
}
